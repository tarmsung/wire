# Caddy reverse proxy for Wire — automatic HTTPS via Let's Encrypt.
# Put this at /etc/caddy/Caddyfile, then: sudo systemctl reload caddy
#
# Caddy fetches and renews the TLS cert automatically (needs ports 80 + 443
# open and the domain's DNS pointing at this server). WebSocket upgrades are
# proxied transparently — no extra config needed.

# Apex is canonical; the Node app listens on localhost:3000.
wirelink.online {
	reverse_proxy localhost:3000
}

# Send www to the apex so links don't get split across two hostnames.
www.wirelink.online {
	redir https://wirelink.online{uri} permanent
}
